<%= form_with(model: product, local: true, class: "product-form") do |form| %>
    <div class="form-group">
      <%= form.label :name, "Product Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-input" %>
    </div>
  
    <div class="form-group">
      <%= form.label :description, "Description", class: "form-label" %>
      <%= form.text_area :description, class: "form-input" %>
    </div>
  
    <div class="form-group">
      <%= form.label :featured_image, "Upload Image", class: "form-label" %>
      <%= form.file_field :featured_image, class: "form-input" %>
    </div>
  
    <div class="form-actions">
      <%= form.submit "Create Product", class: "button submit-button" %>
    </div>
  <% end %>
  